// Prisma schema — Phase 1.5 + AI Bundles
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Shops ────────────────────────────────────────────────────────────────────

model Shop {
  id            Int       @id @default(autoincrement())
  shopDomain    String    @unique @map("shop_domain")
  accessToken   String    @map("access_token")
  scopes        String?
  installedAt   DateTime  @default(now()) @map("installed_at")
  uninstalledAt DateTime? @map("uninstalled_at")

  fbtGroups       FbtGroup[]
  analyticsEvents AnalyticsEvent[]
  sessions        Session[]
  giftRules       GiftRule[]
  shopSettings    ShopSettings?
  aiSuggestions   AiSuggestion[]

  @@map("shops")
}

// ─── Shop Settings ────────────────────────────────────────────────────────────

model ShopSettings {
  shopId                 Int      @id @map("shop_id")
  freeShippingThreshold  Decimal? @map("free_shipping_threshold") @db.Decimal(10, 2)
  currencyCode           String   @default("USD") @map("currency_code")
  updatedAt              DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_settings")
}

// ─── FBT Groups ───────────────────────────────────────────────────────────────

model FbtGroup {
  id          Int      @id @default(autoincrement())
  shopId      Int      @map("shop_id")
  productId   String   @map("product_id")       // Shopify product GID
  title       String?
  bundleType  String   @default("fixed") @map("bundle_type")
  // 'fixed'    — merchant picks exact products, customer can deselect
  // 'flexible' — merchant picks pool, customer picks N from pool
  // 'volume'   — quantity breaks on the same product
  displayMode String   @default("inline") @map("display_mode")
  // 'inline' | 'popup' | 'both'
  minSelect   Int      @default(1) @map("min_select")  // min items customer must pick
  maxSelect   Int      @default(4) @map("max_select")  // max items customer can pick
  isActive    Boolean  @default(true) @map("is_active")
  // AI suggestion metadata
  aiGenerated Boolean  @default(false) @map("ai_generated")
  aiTheme     String?  @map("ai_theme")         // e.g. "Massage Therapist Bundle"
  aiRationale String?  @map("ai_rationale")     // AI explanation for the bundle
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  shop            Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  fbtProducts     FbtProduct[]
  discountTiers   DiscountTier[]
  analyticsEvents AnalyticsEvent[]

  @@unique([shopId, productId])
  @@map("fbt_groups")
}

// ─── FBT Products (within a group) ───────────────────────────────────────────

model FbtProduct {
  id           Int      @id @default(autoincrement())
  groupId      Int      @map("group_id")
  productId    String   @map("product_id")       // Shopify product GID
  position     Int      @default(0)
  poolEligible Boolean  @default(true) @map("pool_eligible")
  // For flexible bundles: all pool products have poolEligible=true
  // For fixed bundles: ignored (all products shown)
  createdAt    DateTime @default(now()) @map("created_at")

  group FbtGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@map("fbt_products")
}

// ─── Discount Tiers (replaces single discount_rules) ─────────────────────────

model DiscountTier {
  id            Int      @id @default(autoincrement())
  groupId       Int      @map("group_id")
  minItems      Int      @map("min_items")        // trigger: customer selects >= minItems
  discountType  String   @map("discount_type")    // 'percentage' | 'fixed' | 'price'
  discountValue Decimal  @map("discount_value") @db.Decimal(10, 2)
  // 'percentage' → % off total
  // 'fixed'      → $ off total
  // 'price'      → flat bundle price (overrides individual prices)
  position      Int      @default(0)              // display order (tier 1, 2, 3...)
  createdAt     DateTime @default(now()) @map("created_at")

  group FbtGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, minItems])
  @@map("discount_tiers")
}

// ─── Gift With Purchase Rules ─────────────────────────────────────────────────

model GiftRule {
  id              Int      @id @default(autoincrement())
  shopId          Int      @map("shop_id")
  name            String                              // merchant label e.g. "Summer GWP"
  thresholdType   String   @map("threshold_type")    // 'cart_value' | 'item_count' | 'fbt_add'
  thresholdValue  Decimal  @map("threshold_value") @db.Decimal(10, 2)
  giftProductId   String   @map("gift_product_id")   // Shopify product GID
  giftVariantId   String   @map("gift_variant_id")   // Shopify variant GID
  giftTitle       String?  @map("gift_title")        // cached for display
  giftImageUrl    String?  @map("gift_image_url")    // cached for display
  maxPerOrder     Int      @default(1) @map("max_per_order")
  showProgressBar Boolean  @default(true) @map("show_progress_bar")
  progressMessage String   @default("You're {amount} away from a free {gift}!") @map("progress_message")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("gift_rules")
}

// ─── AI Bundle Suggestions ────────────────────────────────────────────────────

model AiSuggestion {
  id            Int      @id @default(autoincrement())
  shopId        Int      @map("shop_id")
  theme         String                              // e.g. "Massage Therapist Bundle"
  rationale     String                              // AI explanation
  productIds    String[] @map("product_ids")        // array of Shopify product GIDs
  mainProductId String   @map("main_product_id")    // suggested anchor product
  status        String   @default("pending")        // 'pending' | 'approved' | 'rejected'
  approvedGroupId Int?   @map("approved_group_id")  // set when merchant approves
  creditsUsed   Int      @default(1) @map("credits_used")
  createdAt     DateTime @default(now()) @map("created_at")
  reviewedAt    DateTime? @map("reviewed_at")

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("ai_suggestions")
}

// ─── AI Credit Ledger ─────────────────────────────────────────────────────────

model AiCreditLedger {
  id          Int      @id @default(autoincrement())
  shopId      Int      @map("shop_id")
  delta       Int                                   // positive = credit, negative = debit
  reason      String                                // 'purchase' | 'analysis' | 'refund'
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([shopId])
  @@map("ai_credit_ledger")
}

// ─── Analytics Events ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        BigInt   @id @default(autoincrement())
  shopId    Int      @map("shop_id")
  groupId   Int?     @map("group_id")
  eventType String   @map("event_type")
  // 'view' | 'click' | 'add_to_cart' | 'purchase'
  // 'gift_unlocked' | 'popup_shown' | 'popup_dismissed'
  productId String?  @map("product_id")
  sessionId String?  @map("session_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  shop  Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  group FbtGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([shopId, createdAt])
  @@index([groupId, eventType])
  @@map("analytics_events")
}

// ─── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id          String    @id
  shop        String
  state       String?
  isOnline    Boolean   @default(false) @map("is_online")
  scope       String?
  expires     DateTime?
  accessToken String?   @map("access_token")
  userId      BigInt?   @map("user_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  shopRelation Shop? @relation(fields: [shop], references: [shopDomain])

  @@index([shop])
  @@map("sessions")
}