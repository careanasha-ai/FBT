{
  "name": "fbt-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build && npm run widget:build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "tsc",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "format": "prettier --write .",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx app/db/seed.ts",
    "db:studio": "prisma studio",
    "widget:build": "vite build --config widget/vite.config.ts",
    "widget:dev": "vite build --config widget/vite.config.ts --watch",
    "shopify:dev": "shopify app dev",
    "shopify:deploy": "npm run widget:build && shopify app deploy",
    "shopify:info": "shopify app info"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@shopify/app-bridge-react": "^4.1.6",
    "@shopify/polaris": "^13.0.0",
    "@shopify/shopify-api": "^11.0.0",
    "@shopify/shopify-app-remix": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.0.0",
    "@react-router/node": "^7.0.0",
    "@react-router/serve": "^7.0.0",
    "recharts": "^2.12.7",
    "zod": "^3.23.8",
    "date-fns": "^3.6.0",
    "isbot": "^5.1.0"
  },
  "devDependencies": {
    "@react-router/dev": "^7.0.0",
    "@shopify/cli": "^3.67.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "postcss": "^8.4.39",
    "prettier": "^3.3.3",
    "prisma": "^5.14.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-tsconfig-paths": "^5.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}